#include <iostream>
using namespace std;
int main(){
int m = 5;
for(int i = 0;i <= m;i++){
    for(int j = 1;j <= i;j++){
        if(i % 2 == 0){
            if(j % 2 == 0){
                cout<<"1";
            }
            else{
                cout<<"0";
            }
        }
        else{
            if(j % 2 == 0){
                cout<<"0";
            }
            else{
                cout<<"1";
            }
        }
    }
    cout<<endl;
}
return 0;
}
