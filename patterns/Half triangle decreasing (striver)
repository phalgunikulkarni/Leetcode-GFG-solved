//for printing stars
#include <iostream>
using namespace std;
int main(){
int m = 5;
for(int i = m;i >= 1;i--){
for(int j = 1;j <= i;j++){
cout<<"*"<<" ";
}
cout<<endl;
}
return 0;
}

