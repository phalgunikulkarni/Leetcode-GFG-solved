#include <iostream>
using namespace std;
int main(){
int m = 5;
for(int i = 0;i < m;i++){
    for(int j = 0;j < m - i - 1;j++){
        cout<<" ";
    }
for(int j = 1;j <= 2*i+1;j++){
cout<<"*";
}
cout<<endl;
}
return 0;
}

