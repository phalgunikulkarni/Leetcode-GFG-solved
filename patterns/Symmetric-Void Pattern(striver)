#include <iostream>
using namespace std;
int main() {
  int m = 5;
  for(int i = 1;i<=m;i++){
      for(int j = m;j >= i;j--){
          cout<<"*";
      }
      for(int j = 1;j<i;j++){
          cout<<"  ";
      }
      for(int j = m;j>= i;j--){
          cout<<"*";
      }
      cout<<endl;
  }
 
  for(int i = 1;i<=m;i++){
      for(int j = 1;j<=i;j++){
          cout<<"*";
      }
      for(int j = m-i;j>0;j--){
          cout<<"  ";
      }
      
      for(int j = i;j>=1;j--){
          cout<<"*";
      }
      cout<<endl;
  }
    return 0;
}
