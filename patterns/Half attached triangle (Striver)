#include <iostream>
using namespace std;
int main(){
int m = 5;
for(int i = 1;i <= m;i++){
    for(int j = 0;j < i;j++){
        cout<<"*";
    }
cout<<endl;
}
for(int i = m-1;i>0;i--){
    for(int j = 1;j <= i;j++){
        cout<<"*";
    }
    cout<<endl;
}

return 0;
}
