class Solution {
  public:
    int missingNum(vector<int>& arr) {
        unordered_map<int,int> hash;
        sort(arr.begin(),arr.end());
        
        for(int i = 0;i < arr.size();i++){
            hash[arr[i]]++;
        }
        
        int elem = 1;
        for(int i = 0;i < hash.size();i++){
            if(hash.find(elem) == hash.end()){
                return elem;
            }
            elem++;
        }
        return arr[arr.size()-1] + 1;
    }
};

