// Online C++ compiler to run C++ program online
#include <iostream>
#include<cmath>
#include<algorithm>
#include<vector>
using namespace std;

int main() {
    int n = 840;
    vector<int> div;
    for(int i = 2;i < sqrt(n);i++){
        if(n % i == 0){
            div.push_back(i);
        }
        if(i != n/i)
            div.push_back(n/i);
    }
    div.push_back(1);
    div.push_back(n);
    sort(div.begin(),div.end());
    for(int i = 0;i < div.size();i++)
    cout<<div[i]<<endl;
    
    return 0;
}
