//Euclidean Algorithm
#include <iostream>
#include<cmath>
using namespace std;
int main() {
    int n1 = 18,n2 = 21,gcd = 1;
    int m = min(n1,n2);
    if(m == 1)
        cout<<m;
    else{
    while(n1>0&&n2>0){
        if(n1>=n2){
            n1 = n1-n2;
        }
        else{
            n2 = n2-n1;
        }
    }
    if(n1 == 0){
        gcd = n2;
    }
    else
    gcd = n1;
    
        cout<< gcd;
    }
    return 0;
}

// Online C++ compiler to run C++ program online
#include <iostream>
#include<cmath>
using namespace std;
int main() {
    int n1 = 18,n2 = 21,gcd = 1;
    int m = min(n1,n2);
    if(m == 1)
        cout<<m;
    else{
    for(int i = 1;i<m;i++){
        if((n1 % i == 0) && (n2 % i == 0)){
            gcd = i;
        }
    } 
    cout<<gcd;
    }
    return 0;
}

