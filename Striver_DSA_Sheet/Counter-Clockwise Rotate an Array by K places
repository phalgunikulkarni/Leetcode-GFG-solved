[1,2,3,4,5] ==> [4,5,1,2,3]
#include <bits/stdc++.h>
using namespace std;
void rotate(vector<int> &arr,int k) {
        int n = arr.size();
        for(int p = 1;p <= k;p++){
            int i = 0,j = 1;
            while(i < n-1)
            {swap(arr[i],arr[j]);i++;j++;}
        }
    }
    
int main() {
    vector<int> arr = {1,2,3,4,5};
    rotate(arr,3);
    for(int i = 0;i< arr.size();i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}
