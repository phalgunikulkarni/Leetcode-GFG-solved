[1,2,3,4,5] ==> [3,4,5,1,2]
#include <bits/stdc++.h>
using namespace std;
void rotate(vector<int> &arr,int k) {
        int n = arr.size();
        for(int p = 1;p <= k;p++){
            int i = n-1,j = n-2;
            while(i > 0)
            {swap(arr[i],arr[j]);i--;j--;}
        }
    }
    
int main() {
    vector<int> arr = {1,2,3,4,5};
    rotate(arr,3);
    for(int i = 0;i< arr.size();i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}
