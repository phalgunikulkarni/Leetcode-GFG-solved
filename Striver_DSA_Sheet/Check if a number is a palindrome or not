// Online C++ compiler to run C++ program online
#include <iostream>
#include<cmath>
using namespace std;
int main() {
    int n = 123454321,rev = 0;
    int temp = n;
    while(n > 0){
        int dig = n%10;
        rev = rev *10 +dig;
        n = n/10;
    }
    if (rev == temp){
        cout<<"Palindrome";
    }
    else
    cout<<"Not palindrome";
    return 0;
}
