// Online C++ compiler to run C++ program online
#include <iostream>
#include<cmath>
#include<algorithm>
#include<vector>
using namespace std;

int main() {
    int n = 11;
    bool prime = true;
    for(int i = 2;i < n;i++){
        if(n%i == 0){
            prime = false;
            break;
        }
    }
    if(prime)
    cout<<"True";
    else 
    cout<<"False";
    return 0;
}

//Optimal
#include <iostream>
#include<cmath>
#include<algorithm>
#include<vector>
using namespace std;

int main() {
    int n = 11;
    bool prime = true;
    for(int i = 2;i < sqrt(n);i++){
        if(n%i == 0){
            prime = false;
            break;
        }
    }
    if(prime)
    cout<<"True";
    else 
    cout<<"False";
    return 0;
}
