#include<iostream>

using namespace std;
int main(){
int a[] = {14,10,8,6,2},n=sizeof(a)/sizeof(a[0]);

for(int i=0;i<n;i++){
    cout<<a[i]<<" ";
}
for(int i = 0;i<n-1;i++){
    for(int j = 0;j<n-i-1;j++){
        if(a[j+1]<a[j]){
            swap(a[j+1],a[j]);
        }
        cout<<endl;
    for(int i=0;i<n;i++){
    cout<<a[i]<<" ";
    }
    }
}
cout<<endl;
for(int i=0;i<n;i++){
    cout<<a[i]<<" ";
}
return 0;
}
