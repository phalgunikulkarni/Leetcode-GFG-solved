#include <iostream>

using namespace std;
int main() {
    int arr[] = {14,10,8,6,2},min_ind, n = sizeof(arr)/sizeof(arr[0]);
    
    for(int i = 0;i < n;i++){
        cout<<arr[i]<<" ";
    }
    
    for(int i = 0;i < n-1;i++){
        min_ind = i;
        for(int j = i;j < n;j++){
            if(arr[min_ind] > arr[j]){
                min_ind = j;
            }
        }
        if(i != min_ind){
            swap(arr[i],arr[min_ind]);
        }
        cout<<endl;
    for(int i = 0;i < n;i++){
        cout<<arr[i]<<" ";
    }
    }
    cout<<endl;
    for(int i = 0;i < n;i++){
        cout<<arr[i]<<" ";
    }
    return 0;
}
