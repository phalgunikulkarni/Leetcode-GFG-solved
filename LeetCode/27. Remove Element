class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        vector<int> expected;
        
        for(int i = 0;i < nums.size();i++){
            if(nums[i] != val){
                expected.push_back(nums[i]);
            }
        }
        nums = expected;
        return nums.size();
    }
};
