class Solution {
public:
    int majorityElement(vector<int>& nums) {
     unordered_map<int,int> hash;
    int maj = INT_MIN;
     for(int i = 0;i< nums.size();i++){
        hash[nums[i]]++;
     }
     for(int i =0;i < nums.size();i++){
        if(hash[nums[i]] > (nums.size()/2)){
            maj = max(nums[i],maj);
        }
     }
     return maj;
    }
};
