class Solution {
public:
    bool containsNearbyDuplicate(vector<int>& nums, int k) {
        unordered_map<int,int> freq;

        for(int i = 0; i < nums.size(); i++) {
            freq[nums[i]]++;

            if(freq[nums[i]] > 1)
                return true;

            if(i >= k) {
                freq[nums[i - k]]--;
                if(freq[nums[i - k]] == 0)
                    freq.erase(nums[i - k]);
            }
        }

        return false;
    }
};
