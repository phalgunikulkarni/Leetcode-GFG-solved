class Solution {
public:
    void rotate(vector<int>& nums, int k) {
        vector<int> res;
        int n = nums.size();
        k = k%n;
        if(n < k){
            return;
        }
        for(int i = n-k;i < n;i++){
            res.push_back(nums[i]);
        }
        for(int i = 0;i < n-k;i++){
            res.push_back(nums[i]);
        }
        nums = res;
    }   
};

class Solution {
public:
    void rev (vector<int> &nums, int start, int end){
        int i =start,j = end;
        while(i < j){
            swap(nums[i],nums[j]);
            i++;j--;
        }
    }
    void rotate(vector<int>& nums, int k) {
        vector<int> res;
        int n = nums.size();
        k = k % n;
        if(n < k){
            return;
        }
        rev (nums, 0, n-k-1);
        rev (nums, n-k, n-1);
        rev (nums, 0, n-1);
    }   
};
